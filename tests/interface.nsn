type LinesA : Lines {}

type LinesB : Lines {
    data: str
}

type Lines interface {
    lines(lines: Self, text: str): [str]
}

a: LinesA = {}
b: LinesB = {data="LinesB 1"}
c: LinesB = {data="LinesB 2"}

main = [
    lines_with(a)
    lines_with(b)
    lines_with(c)
]

lines_with(lines: Lines) =
    lines.lines("implementation omitted")

LinesA.lines(_: Self, text) =
    ["LinesA", text]

LinesB.lines(lines: Self, text) =
    ["LinesB", lines.data, text]
